{
  "name": "voquill-root",
  "version": "1.3.18",
  "private": true,
  "license": "AGPL-3.0-only",
  "scripts": {
    "deps:check": "node scripts/check-deps.mjs",
    "predev": "npm run deps:check",
    "dev": "vite --host 127.0.0.1",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "harden:check": "node scripts/check-tauri-hardening.mjs",
    "typecheck": "tsc --noEmit",
    "prebuild": "npm run deps:check",
    "build": "npm run typecheck && vite build",
    "openvino:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-openvino-runtime.ps1 -UseNightly",
    "preview": "vite preview",
    "cargo": "node scripts/cargo-runner.mjs",
    "cargo:check": "node scripts/cargo-runner.mjs check --manifest-path src-tauri/Cargo.toml",
    "tauri": "node scripts/tauri-runner.mjs",
    "tauri:dev": "node scripts/tauri-runner.mjs dev",
    "tauri:build": "node scripts/tauri-runner.mjs build"
  },
  "dependencies": {
    "@tabler/icons-preact": "^3.36.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-shell": "^2",
    "preact": "^10.28.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@preact/preset-vite": "^2.10.2",
    "@tauri-apps/cli": "^2.9.6",
    "@types/node": "^22.15.3",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.4.1"
  }
}
