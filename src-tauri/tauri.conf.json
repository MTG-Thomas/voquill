{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Voquill",
  "version": "1.3.21",
  "identifier": "org.voquill.foss",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "enableGTKAppId": true,
    "windows": [
      {
        "label": "main",
        "title": "Voquill",
        "width": 430,
        "height": 700,
        "resizable": true,
        "minWidth": 400,
        "minHeight": 400,
        "center": true,
        "visible": false,
        "closable": true,
        "decorations": false
      },
      {
        "label": "overlay",
        "title": "Voquill Status",
        "width": 260,
        "height": 140,
        "resizable": false,
        "center": false,
        "visible": false,
        "closable": false,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "focusable": false,
        "acceptFirstMouse": false,
        "url": "/overlay"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost http://localhost:1420 http://127.0.0.1:1420 ws://localhost:1421 ws://127.0.0.1:1421 https://api.openai.com https://huggingface.co https://api.github.com; img-src 'self' asset: http://asset.localhost http://localhost:1420 http://127.0.0.1:1420 data:; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },

  "bundle": {
    "active": true,
    "publisher": "Jack Brumley",
    "category": "DeveloperTool",
    "copyright": "",
    "shortDescription": "Voice dictation app",
    "longDescription": "Cross-platform push-to-talk dictation app with Whisper-powered speech recognition",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.svg",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "resources": [],
    "externalBin": [],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "linux": {
      "deb": {
        "desktopTemplate": "packaging/org.voquill.foss.desktop.hbs",
        "depends": ["libgtk-layer-shell0", "libpulse0", "libappindicator3-1"],
        "files": {
          "/usr/share/metainfo/org.voquill.foss.metainfo.xml": "org.voquill.foss.metainfo.xml"
        }
      },
      "rpm": {
        "desktopTemplate": "packaging/org.voquill.foss.desktop.hbs",
        "depends": ["gtk-layer-shell", "webkit2gtk4.1", "pulseaudio-libs", "libappindicator-gtk3"],
        "files": {
          "/usr/share/metainfo/org.voquill.foss.metainfo.xml": "org.voquill.foss.metainfo.xml"
        }
      },
      "appimage": {
        "bundleMediaFramework": false,
        "files": {
          "/usr/share/metainfo/org.voquill.foss.metainfo.xml": "org.voquill.foss.metainfo.xml",
          "/usr/share/appdata/org.voquill.foss.appdata.xml": "org.voquill.foss.metainfo.xml"
        }
      }
    }
  },
  "plugins": {}
}
